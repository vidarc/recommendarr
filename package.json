{
	"name": "recommendarr",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development node --env-file=.env --experimental-strip-types --experimental-transform-types src/server/server.ts",
		"build": "vp build && vp build --ssr entry-server.tsx --outDir ../../dist/ssr && tsc -b tsconfig.server.json && tsc -p tsconfig.client.json --noEmit",
		"docker:build": "docker build . -t recommendarr",
		"docker:run": "docker run -p 8080:8080 --env-file .env recommendarr",
		"test:e2e": "./scripts/e2e.sh",
		"lint": "vp check",
		"test": "vp test",
		"test:watch": "vp test watch",
		"prepare": "vp config --hooks-only",
		"publish:changelog": "./scripts/publish.sh"
	},
	"dependencies": {

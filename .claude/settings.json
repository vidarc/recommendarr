{
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
	},
	"mcpServers": {
		"vite-plus": {
			"command": "npx",
			"args": ["vp", "mcp"]
		}
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "yarn vp check 2>&1 || true",
						"timeout": 120,
						"statusMessage": "Running format, lint, and typecheck..."
					}
				]
			}
		]
	}
}

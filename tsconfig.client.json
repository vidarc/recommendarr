{
	"extends": "./tsconfig.json",
	"include": ["src/client/**/*", "src/shared/**/*"],
	"compilerOptions": {
		"composite": true,
		"target": "es2024",
		"lib": ["es2024", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"outDir": "dist/client",
		"types": ["@testing-library/jest-dom"],
		"paths": {
			"@shared/*": ["./src/shared/*"]
		}
	}
}
